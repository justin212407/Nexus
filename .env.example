# NEXUS Environment Variables
# Copy this file to .env and fill in your values

# === REQUIRED IN ALL MODES (choose one) ===
# Option 1: Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# Option 2: OpenRouter with free models (uses DeepSeek by default)
# Get free key at: https://openrouter.io
OPENROUTER_API_KEY=sk-or-v1-...

# === DEMO MODE - set true for all testing and demo day ===
DEMO_MODE=true

# === REQUIRED FOR LIVE MODE ONLY ===
INTERCOM_ACCESS_TOKEN=
INTERCOM_WEBHOOK_SECRET=your_webhook_secret_here
SLACK_BOT_TOKEN=xoxb-...
SLACK_ESCALATION_CHANNEL=#nexus-alerts
SENTRY_ORG_SLUG=your-org-slug
GITHUB_TOKEN=ghp_...
LINEAR_API_KEY=lin_api_...

# === OPTIONAL - defaults shown ===
CONFIDENCE_THRESHOLD=70
DATABASE_URL=sqlite:///nexus.db
